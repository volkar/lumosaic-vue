{
  "name": "lumosaic",
  "version": "1.1.6",
  "description": "Adaptive, data-driven image and video mosaic gallery with intelligent row layout for Vue 3 and Nuxt 4",
  "author": "Sergey Volkar <volkar.sergey@gmail.com>",
  "license": "MIT",
  "homepage": "https://lumosaic.syntheticsymbiosis.com",
  "repository": "git+https://github.com/volkar/lumosaic-vue.git",
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "nuxt4",
    "gallery",
    "mosaic",
    "masonry",
    "images",
    "grid"
  ],
  "type": "module",
  "main": "./dist/lumosaic.umd.js",
  "module": "./dist/lumosaic.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/lumosaic.es.js",
      "require": "./dist/lumosaic.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt-module.es.js",
      "require": "./dist/nuxt-module.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.8",
    "@nuxt/schema": "^4.4.8",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.1",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.0"
  }
}
